<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/colorSurface"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_back_arrow"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment"
                android:textColor="@color/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/rounded_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Booking Summary"
                android:textColor="@color/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Movie"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvPayMovieName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Avengers: Endgame"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Theatre"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvPayTheatreName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="PVR: ICON, Nagpur"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Show Time"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvPayShowTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Today, 07:30 PM"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Seats"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvPaySeats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="F12, F13"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tickets"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvPaySeatCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="2 Tickets"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:background="@color/colorDivider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Amount"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvPayTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="₹450.00"
                    android:textColor="#FF5252"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/rounded_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textColor="@color/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <RadioGroup
                android:id="@+id/rgPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/rbUPI"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="  UPI (GPay / PhonePe)"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:buttonTint="#FF5252"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="  Credit / Debit Card"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:buttonTint="#FF5252" />

                <RadioButton
                    android:id="@+id/rbNetBanking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  Net Banking"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:buttonTint="#FF5252" />
            </RadioGroup>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPayNow"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="16dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/rounded_button_red"
            android:backgroundTint="#FF5252"
            android:text="Pay Now"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false" />
    </LinearLayout>

</ScrollView>